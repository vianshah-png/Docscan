# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a server-side secret and should NOT be prefixed with VITE_.
# Set this in your Vercel Environment Variables or local .env file.
GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL: The URL where this app is hosted (optional, automatically set by Vercel).
APP_URL="https://your-app-url.vercel.app"
